# ── AssemblyAI ──────────────────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_SPEECH_MODEL=universal-2

# ── MongoDB Atlas ───────────────────────────────────────────────────────────
# Get the connection string from Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=meeting_assistant

# ── Gemini (Google AI Studio API key) ───────────────────────────────────────
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# ── App ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
